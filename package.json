{
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint --ext .ts,.js .",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(ts|json)\""
  },
  "lint-staged": {
    "frontend/src/**/.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "backend/src/**/.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "lint-staged": "^16.2.7"
  }
}
